# Frontend Environment Variables (Astro Build)
# These are bundled into the static site and visible to users
# Only use PUBLIC_ prefix for variables needed by the browser

# Cloudflare Turnstile Site Key (public)
# Get from: https://dash.cloudflare.com/ → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADgV_7YQdEJ-NjPe

# NukeHub API origin (public)
# Contact form submits to {PUBLIC_API_URL}/contact
# Survey forms submit to {PUBLIC_API_URL}/survey
# Admin dashboard reads from {PUBLIC_API_URL}/admin
PUBLIC_API_URL=https://api.nukehub.org

# Cloudflare Web Analytics token (public - optional)
# Get from: https://dash.cloudflare.com/ → Web Analytics → Add site
# Leave empty to disable analytics entirely.
PUBLIC_CF_ANALYTICS_TOKEN=

# NukeAuth Configuration (public - used by browser)
# These are safe to expose to the frontend
PUBLIC_AUTH_URL=https://auth.nukehub.org
PUBLIC_AUTH_REALM=nukehub
PUBLIC_AUTH_CLIENT_ID=nukehub-web
