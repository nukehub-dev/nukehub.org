# Backend Environment Variables (NukeHub API Server)
# These are used by the Go server at runtime
# NEVER commit this file - keep secrets safe

# Server
# The port the API server listens on
PORT=3000

# SQLite database file path
# Use ./data/nukehub.db for local Go runs, /app/data/nukehub.db for Docker.
DATABASE_PATH=./data/nukehub.db

# Cloudflare Turnstile Secret Key (private - never expose to frontend)
# Get from: https://dash.cloudflare.com/ → Turnstile
TURNSTILE_SECRET_KEY=your-secret-key-here

# SMTP Settings (your mailcow server)
SMTP_HOST=mail.nukehub.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email-user
SMTP_PASS=your-email-password

# Where to receive emails
CONTACT_TO_EMAIL=contact@nukehub.org
SURVEY_TO_EMAIL=survey@nukehub.org

# Newsletter campaign settings
# HMAC secret that signs one-click unsubscribe tokens. REQUIRED in production;
# without it tokens are invalidated on every restart. Generate with:
#   openssl rand -hex 32
NEWSLETTER_TOKEN_SECRET=your-random-hex-secret
# Sender addresses offered in the admin compose UI. Both must be deliverable
# by SMTP_USER (e.g. mailcow aliases of the SMTP_USER mailbox, with send-as
# permission), and are DKIM-signed like any other @nukehub.org mail.
# NEWSLETTER_FROM_EMAIL is for hand-written campaigns, BLOG_FROM_EMAIL for
# automated blog-post notifications. Point both at the same address for a
# single sender identity.
NEWSLETTER_FROM_EMAIL=news@nukehub.org
BLOG_FROM_EMAIL=blog@nukehub.org
NEWSLETTER_FROM_NAME=NukeHub
# Delay between individual newsletter sends, in milliseconds (rate limit).
NEWSLETTER_SEND_DELAY_MS=1000
# Public origins used in email links (unsubscribe page + one-click API URL).
SITE_URL=https://nukehub.org
API_PUBLIC_URL=https://api.nukehub.org

# Blog → newsletter auto-send (opt-in).
# When true, the server polls the blog RSS feed and automatically sends a
# campaign from BLOG_FROM_EMAIL for every new post. The first poll only
# records the newest post — it never sends the archive backlog.
BLOG_AUTO_SEND=false
BLOG_RSS_URL=https://blog.nukehub.org/rss.xml
BLOG_URL=https://blog.nukehub.org
# Poll interval in milliseconds (minimum 60000; default 30 minutes).
BLOG_RSS_POLL_INTERVAL_MS=1800000

# Bounce processing (opt-in).
# Campaign emails use BOUNCE_EMAIL as their envelope sender, so async
# bounces land there. When BOUNCE_CHECK_ENABLED=true, the server polls that
# mailbox over IMAP and removes hard-bounced (5xx) addresses from the
# subscriber list. BOUNCE_EMAIL must be a real mailbox (or an alias
# delivering to the polled mailbox) in mailcow.
BOUNCE_EMAIL=bounces@nukehub.org
BOUNCE_CHECK_ENABLED=false
# IMAP connection defaults to the SMTP host/credentials. Override when the
# bounce mailbox is a separate mailcow account:
# BOUNCE_IMAP_HOST=mail.nukehub.org
# BOUNCE_IMAP_PORT=993
# BOUNCE_IMAP_USER=bounces@nukehub.org
# BOUNCE_IMAP_PASS=...
# BOUNCE_IMAP_FOLDER=INBOX
# Poll interval in milliseconds (minimum 300000; default 1 hour).
BOUNCE_CHECK_INTERVAL_MS=3600000

# CORS - comma separated list of allowed origins
# For local dev/preview, also include the site's origin, e.g.
# ALLOWED_ORIGINS=https://nukehub.org,https://www.nukehub.org,http://localhost:4321
ALLOWED_ORIGINS=https://nukehub.org,https://www.nukehub.org

# NukeAuth configuration for admin token verification
# NukeAuth is Keycloak-backed; these must match the static site's PUBLIC_AUTH_* values.
# Admin access is granted by the "survey-admin" client role under AUTH_CLIENT_ID,
# not by an email allow-list. Configure the role in Keycloak and assign it to admin users.
AUTH_URL=https://auth.nukehub.org
AUTH_REALM=nukehub
AUTH_CLIENT_ID=nukehub-web
