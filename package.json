{
  "name": "nukehub.org",
  "version": "2.0.0",
  "description": "NukeHub flagship brand site — Astro + React Islands + Tailwind v4",
  "type": "module",
  "scripts": {
    "dev": "rm -rf node_modules/.vite && node scripts/debug-pages.js --enable && astro dev --host",
    "dev:fast": "node scripts/debug-pages.js --enable && astro dev --host",
    "prebuild": "node scripts/inject-sw-cache.js",
    "build": "node scripts/debug-pages.js --disable && astro build",
    "clean": "rm -rf .astro node_modules/.astro node_modules/.vite dist",
    "build:clean": "npm run clean && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,scss,json,md,yml,yaml}\" \"*.{json,md,yml,yaml}\" \"api-server/*.{yml,yaml}\" \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,scss,json,md,yml,yaml}\" \"*.{json,md,yml,yaml}\" \"api-server/*.{yml,yaml}\" \".github/**/*.{yml,yaml}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "astro preview --host",
    "seed:surveys": "node scripts/seed-surveys.mjs",
    "seed:newsletter": "node scripts/seed-newsletter.mjs",
    "astro": "astro"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nukehub-dev/nukehub.org.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nukehub-dev/nukehub.org/issues"
  },
  "homepage": "https://github.com/nukehub-dev/nukehub.org#readme",
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/list": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@marsidev/react-turnstile": "^1.5.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-table": "^8.21.3",
    "astro": "^7.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "geist": "^1.7.2",
    "keycloak-js": "^26.2.4",
    "lenis": "^1.3.25",
    "lucide-react": "^1.24.0",
    "postprocessing": "^6.39.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "satori": "^0.28.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.17",
    "better-sqlite3": "^12.11.1",
    "js-yaml": "^5.2.1",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.35.3",
    "turndown": "^7.2.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.111.0"
  }
}
