{
  "name": "nukehub.org",
  "version": "1.0.0",
  "description": "NukeHub flagship brand site — Astro + React Islands + Tailwind v4",
  "type": "module",
  "scripts": {
    "dev": "rm -rf node_modules/.vite && node scripts/debug-pages.js --enable && astro dev --host",
    "dev:fast": "node scripts/debug-pages.js --enable && astro dev --host",
    "build": "node scripts/debug-pages.js --disable && astro build",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,scss,json,md}\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,scss,json,md}\" \"*.json\" \"*.md\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "astro preview",
    "astro": "astro"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nukehub-dev/nukehub.org.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nukehub-dev/nukehub.org/issues"
  },
  "homepage": "https://github.com/nukehub-dev/nukehub.org#readme",
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@marsidev/react-turnstile": "^1.5.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "keycloak-js": "^26.2.4",
    "lenis": "^1.3.23",
    "lucide-react": "^1.18.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/typography": "^0.5.20",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3"
  }
}
