---
import { getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import { EventsContainer } from '@components/events/EventsContainer';
import { expandEvents } from '@lib/events';
import type { CalendarEvent } from '@lib/events';

// Load events from YAML files in src/content/events/
const entries = await getCollection('events');

// Map content collection entries to CalendarEvent (filename = id)
const baseEvents: CalendarEvent[] = entries.map((entry) => ({
  id: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  start: entry.data.start,
  end: entry.data.end,
  venue: entry.data.venue,
  organizer: entry.data.organizer,
  speakers: entry.data.speakers,
  url: entry.data.url,
  meetingUrl: entry.data.meetingUrl,
  backgroundColor: entry.data.backgroundColor,
  textColor: entry.data.textColor,
  recurrence: entry.data.recurrence as CalendarEvent['recurrence'],
}));

// Expand recurring templates into individual instances
const events = expandEvents(baseEvents);

const title = 'Events';
const description = 'Discover upcoming nuclear technology events, workshops, hackathons, and community gatherings hosted by NukeHub.';
const keywords = 'nukehub, events, calendar, nuclear, workshops, hackathons, summits, conferences';
const permalink = '/events';
---

<PageLayout
  title={title}
  description={description}
  keywords={keywords}
  permalink={permalink}
>
  <div class="space-y-6">
    <div class="text-center sm:text-left">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">Events</h1>
      <p class="text-muted-foreground max-w-2xl">
        Discover upcoming nuclear technology events, workshops, hackathons, and community gatherings.
      </p>
    </div>

    <EventsContainer client:load events={events} />
  </div>
</PageLayout>
