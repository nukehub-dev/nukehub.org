---
import BaseLayout from "@layouts/BaseLayout.astro";
import { NukeidePage } from "@modules/projects/nuke-ide/components/NukeidePage";
import type { NukeideData } from "@modules/projects/nuke-ide/types";
import { loadYaml } from "@lib/loadYaml";
import { getCollection } from "astro:content";

const data = loadYaml<NukeideData>("projects/nuke-ide/data/page.yml");

// Load project metadata from content collection to avoid duplication
const projectEntries = await getCollection("projects");
const nukeideEntry = projectEntries.find((entry) => entry.id === "nuke-ide");

const title = nukeideEntry?.data.title ?? "NukeIDE";
const description =
  nukeideEntry?.data.description ??
  "Open-source Integrated Development Environment for nuclear simulation and engineering.";
const permalink = nukeideEntry?.data.permalink ?? "/nuke-ide";
const image =
  nukeideEntry?.data.image ?? "/assets/images/projects/nuke-ide/hero-lite.png";
---

<BaseLayout
  title={title}
  description={description}
  permalink={permalink}
  image={image}
>
  <NukeidePage
    client:load
    data={data}
    title="Nuke"
    titleHighlight="IDE"
    description={description}
  />
</BaseLayout>
