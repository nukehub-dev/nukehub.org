---
import BaseLayout from "@layouts/BaseLayout.astro";
import ReactorCore404 from "@components/illustrations/ReactorCore404.astro";

const title = "Offline — Signal Lost";
const description =
  "You are currently offline. The reactor is running on backup power.";
---

<BaseLayout
  title={title}
  description={description}
  permalink="/offline"
  showFooter={false}
>
  <section
    class="relative flex min-h-[calc(100vh-4rem)] flex-col items-center justify-center overflow-hidden px-4 text-center"
  >
    {/* Ambient reactor glow */}
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.07]"
      aria-hidden="true"
      style="background: radial-gradient(circle at 50% 48%, var(--primary) 0%, transparent 55%);"
    >
    </div>

    {/* Code badge */}
    <div class="relative z-10 mb-6 animate-text-reveal animate-text-reveal-1">
      <span
        class="inline-flex items-center rounded-full border border-primary/20 bg-card px-4 py-1.5 font-mono text-sm font-semibold text-primary shadow-sm"
      >
        Offline
      </span>
    </div>

    {/* Animated reactor illustration */}
    <div
      class="relative z-10 mb-10 flex h-64 w-64 items-center justify-center animate-reactor-entrance sm:h-80 sm:w-80"
    >
      <ReactorCore404 />
    </div>

    {/* Message */}
    <h1
      class="relative z-10 max-w-lg text-3xl font-semibold tracking-tight text-foreground animate-text-reveal animate-text-reveal-2 sm:text-5xl"
    >
      Signal lost
    </h1>
    <p
      class="relative z-10 mt-3 max-w-md text-base text-muted-foreground animate-text-reveal animate-text-reveal-3 sm:text-lg"
    >
      The reactor is running on backup power. Some pages may not be available
      until your connection returns.
    </p>

    {/* Status indicators */}
    <div
      class="relative z-10 mt-6 flex flex-wrap items-center justify-center gap-3 text-xs font-medium text-muted-foreground animate-text-reveal animate-text-reveal-3"
    >
      <span
        class="inline-flex items-center gap-1.5 rounded-full bg-muted px-3 py-1"
      >
        <span
          class="h-1.5 w-1.5 rounded-full bg-destructive animate-pulse"
          aria-hidden="true"></span>
        Network disconnected
      </span>
      <span
        class="inline-flex items-center gap-1.5 rounded-full bg-muted px-3 py-1"
      >
        <span
          class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"
          aria-hidden="true"></span>
        Cached mode active
      </span>
    </div>

    {/* CTA */}
    <div class="relative z-10 mt-10 animate-text-reveal animate-text-reveal-3">
      <button
        type="button"
        onclick="window.location.reload()"
        class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        Retry connection
      </button>
    </div>

    {/* Decorative particles */}
    <div
      class="pointer-events-none absolute inset-0 overflow-hidden"
      aria-hidden="true"
    >
      {
        Array.from({ length: 24 }).map((_, i) => {
          const left = 10 + ((i * 37) % 80);
          const top = 15 + ((i * 53) % 70);
          const delay = (i * 0.12) % 3;
          const duration = 2 + ((i * 0.23) % 3);
          return (
            <span
              class="absolute h-1 w-1 rounded-full bg-primary/30"
              style={{
                left: `${left}%`,
                top: `${top}%`,
                animation: `pulse-slow ${duration}s ease-in-out infinite`,
                animationDelay: `${delay}s`,
              }}
            />
          );
        })
      }
    </div>
  </section>
</BaseLayout>
