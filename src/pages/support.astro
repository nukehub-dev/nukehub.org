---
import ManualPage from '@components/manual/ManualPage.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('manual', 'support');
if (!entry) {
  throw new Error('Manual entry "support" not found');
}
const { Content, headings } = await entry.render();
---

<ManualPage entry={entry} headings={headings}>
  <Content />
</ManualPage>
