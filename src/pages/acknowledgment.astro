---
import BaseLayout from '@layouts/BaseLayout.astro';
import { AcknowledgmentPageContent } from '@modules/acknowledgment/components/AcknowledgmentPageContent';
import { getCollection } from 'astro:content';

const sponsorEntries = await getCollection('sponsors');
const sponsors = sponsorEntries.map((entry) => ({
  id: entry.id,
  name: entry.data.name,
  image: entry.data.image,
  url: entry.data.url,
  acknowledgment: entry.data.acknowledgment,
  tier: entry.data.tier,
}));
---

<BaseLayout
  title="Acknowledgment"
  description="We extend our sincere gratitude to the organizations and individuals who make NukeHub possible."
  permalink="/acknowledgment"
>
  <AcknowledgmentPageContent client:load sponsors={sponsors} />
</BaseLayout>
