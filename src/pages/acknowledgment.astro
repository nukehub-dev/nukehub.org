---
import ManualPage from '@modules/manual/components/ManualPage.astro';
import { SponsorList } from '@modules/sponsors/components/SponsorList';
import { getEntry, getCollection, render } from 'astro:content';

const entry = await getEntry('manual', 'acknowledgment');
if (!entry) {
  throw new Error('Manual entry "acknowledgment" not found');
}
const { Content, headings } = await render(entry);

// Load sponsors from content collection
const sponsorEntries = await getCollection('sponsors');
const sponsors = sponsorEntries.map((entry) => ({
  id: entry.id,
  name: entry.data.name,
  image: entry.data.image,
  url: entry.data.url,
  acknowledgment: entry.data.acknowledgment,
  tier: entry.data.tier,
}));
---

<ManualPage entry={entry} headings={headings}>
  <Content />

  <SponsorList slot="after" sponsors={sponsors} client:load />
</ManualPage>
