---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { PeopleGrid } from "@modules/people/components/PeopleGrid";
import { PeopleFloatingDots } from "@modules/people/components/decorations/PeopleFloatingDots";
import type { Person, PeopleCategory } from "@modules/people/types";

// Load people and categories from YAML files
const peopleEntries = await getCollection("people");
const categoryEntries = await getCollection("peopleCategories");

// Map to typed objects
const people: Person[] = peopleEntries.map((entry) => ({
  id: entry.id,
  name: entry.data.name,
  image: entry.data.image,
  organization: entry.data.organization,
  role: entry.data.role,
  location: entry.data.location,
  bio: entry.data.bio,
  email: entry.data.email,
  phone: entry.data.phone,
  url: entry.data.url,
  whatsapp: entry.data.whatsapp,
  signal: entry.data.signal,
  linkedin: entry.data.linkedin,
  facebook: entry.data.facebook,
  instagram: entry.data.instagram,
  github: entry.data.github,
  gitlab: entry.data.gitlab,
  bitbucket: entry.data.bitbucket,
  stackoverflow: entry.data.stackoverflow,
  scholar: entry.data.scholar,
  orcid: entry.data.orcid,
  researchgate: entry.data.researchgate,
  zotero: entry.data.zotero,
  youtube: entry.data.youtube,
  mastodon: entry.data.mastodon,
  bluesky: entry.data.bluesky,
  discord: entry.data.discord,
  telegram: entry.data.telegram,
  medium: entry.data.medium,
  tiktok: entry.data.tiktok,
  threads: entry.data.threads,
  x: entry.data.x,
  twitch: entry.data.twitch,
  reddit: entry.data.reddit,
  category: entry.data.category,
}));

// Group people by their category
const peopleByCategory = new Map<string, Person[]>();
for (const person of people) {
  if (!peopleByCategory.has(person.category)) {
    peopleByCategory.set(person.category, []);
  }
  peopleByCategory.get(person.category)!.push(person);
}

// Build categories sorted by explicit order (fallback to title alphabetical)
const peopleCategories: PeopleCategory[] = categoryEntries
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999))
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    children: peopleByCategory.get(entry.data.title) || [],
  }));

const title = "People";
const description =
  "Meet the people behind NukeHub — researchers, engineers, and enthusiasts advancing nuclear technology.";
const keywords =
  "nukehub, people, team, members, nuclear, community, researchers, engineers";
const permalink = "/people";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  permalink={permalink}
>
  <!-- Hero -->
  <section class="relative pt-28 pb-16 text-center overflow-hidden">
    <PeopleFloatingDots client:visible />
    <div
      class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"
    >
    </div>

    <div class="relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary mb-8"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          Our Community
        </div>
        <h1
          class="text-5xl font-bold tracking-tight text-foreground sm:text-6xl lg:text-7xl"
        >
          Meet the <span
            class="bg-gradient-to-r from-primary to-[color-mix(in_oklch,var(--primary)_60%,var(--foreground))] bg-clip-text text-transparent inline-block"
            >People</span
          >
        </h1>
        <p
          class="mt-6 text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed"
        >
          Researchers, engineers, and enthusiasts driving nuclear technology
          forward at NukeHub.
        </p>
      </div>
    </div>
  </section>

  <!-- People Grid -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-16">
    <PeopleGrid client:load categories={peopleCategories} />
  </div>
</BaseLayout>
