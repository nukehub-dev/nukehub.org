---
import { getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import { RoadmapBoard } from "@modules/roadmap/components/RoadmapBoard";

const entries = await getCollection("roadmap");
const sortedEntries = entries.sort(
  (a, b) => (a.data.order ?? Infinity) - (b.data.order ?? Infinity),
);

const items = await Promise.all(
  sortedEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      id: entry.id,
      title: entry.data.title,
      description: entry.data.description,
      status: entry.data.status,
      targetQuarter: entry.data.targetQuarter,
      relatedProject: entry.data.relatedProject,
      ghIssueUrl: entry.data.ghIssueUrl,
    };
  }),
);

const title = "Roadmap";
const description =
  "See what NukeHub is building next, what is in progress, and what has already shipped.";
const keywords =
  "nukehub, roadmap, changelog, open source, nuclear engineering, projects";
const permalink = "/roadmap";
---

<PageLayout
  title={title}
  description={description}
  keywords={keywords}
  permalink={permalink}
>
  <div class="mb-10 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
      Public <span
        class="bg-gradient-to-r from-primary to-[color-mix(in_oklch,var(--primary)_60%,var(--foreground))] bg-clip-text text-transparent inline-block"
        >Roadmap</span
      >
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-muted-foreground">
      A transparent view of upcoming work, active development, shipped features,
      and ideas parked for later review.
    </p>
  </div>

  <RoadmapBoard client:load items={items} />
</PageLayout>
