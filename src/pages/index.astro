---
import BaseLayout from '@layouts/BaseLayout.astro';
import { HeroSection } from '@components/home/HeroSection';
import { ProjectsGrid } from '@components/home/ProjectsGrid';
import { JoinCTA } from '@components/home/JoinCTA';
---

<BaseLayout
  description="NukeHub is a pioneering platform dedicated to the exploration and advancement of nuclear technology."
  keywords="nukehub, nuclear, technology, science, open source, innovation, collaboration, community, simulation, discussions"
  permalink="/"
>
  <HeroSection client:load />

  <div class="border-t border-border/50">
    <ProjectsGrid client:load />
  </div>

  <div class="border-t border-border/50">
    <JoinCTA client:load />
  </div>
</BaseLayout>
