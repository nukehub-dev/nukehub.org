---
import BaseLayout from '@layouts/BaseLayout.astro';
import { HeroSection } from '@modules/home/components/HeroSection';
import { MissionStrip } from '@modules/home/components/MissionStrip';
import { ProjectsGrid } from '@modules/home/components/ProjectsGrid';
import { IntegrationsSection } from '@modules/home/components/IntegrationsSection';
import { EnhancedCTA } from '@modules/home/components/EnhancedCTA';

import { TestimonialsSection } from '@modules/home/components/TestimonialsSection';
import { InstitutionsSection } from '@modules/home/components/InstitutionsSection';
import { PageLoader } from '@components/shared/PageLoader';
import { Footer } from '@components/layout/Footer';

import { loadYaml } from '@lib/loadYaml';
import { getCollection } from 'astro:content';
import type {
  HeroData,
  MissionData,
  IntegrationsData,
  TestimonialsSectionData,
  CTAData,
} from '@modules/home/types';
import type { Sponsor } from '@modules/home/types/sponsor';

// Load homepage data from YAML
const heroData = loadYaml<HeroData>('home/data/hero.yml');
const missionData = loadYaml<MissionData>('home/data/mission.yml');

const integrationsData = loadYaml<IntegrationsData>('home/data/integrations.yml');
const testimonialsSectionData = loadYaml<TestimonialsSectionData>('home/data/testimonials.yml');
const trustData = loadYaml<{ badge: { text: string; showLiveDot?: boolean }; sectionTitle: string; subtitle: string }>('home/data/trust.yml');
const ctaData = loadYaml<CTAData>('home/data/cta.yml');

// Load projects from content collection
const projectEntries = await getCollection('projects');
const allProjects = projectEntries.map((entry) => ({
  title: entry.data.title,
  description: entry.data.description || '',
  url: entry.data.url || '',
  source: entry.data.source || '',
  newpage: entry.data.newpage ?? false,
  image: entry.data.image,
  tags: entry.data.tags,
}));
const projects = allProjects.slice(0, 4);

// Load testimonials from content collection
const testimonialEntries = await getCollection('testimonials');
const testimonials = testimonialEntries.map((entry) => entry.data);

// Load integrations from content collection
const integrationEntries = await getCollection('integrations');
const allIntegrations = integrationEntries.map((entry) => entry.data);
const integrations = allIntegrations.slice(0, 12);

// Load sponsors from content collection
const sponsorEntries = await getCollection('sponsors');
const sponsors: Sponsor[] = sponsorEntries.map((entry) => ({
  name: entry.data.name,
  image: entry.data.image,
  url: entry.data.url,
  acknowledgment: entry.data.acknowledgment,
  tier: entry.data.tier,
}));
---

<BaseLayout
  description="NukeHub is a pioneering platform dedicated to the exploration and advancement of nuclear technology."
  keywords="nukehub, nuclear, technology, science, open source, innovation, collaboration, community, simulation, discussions"
  permalink="/"
  htmlClass="homepage"
  showFooter={false}
>
  <PageLoader client:load />

  <HeroSection client:load data={heroData} />

  <MissionStrip client:visible data={missionData} />

  <ProjectsGrid
    client:visible
    projects={projects}
    totalCount={allProjects.length}
    viewAllHref="/projects"
  />

  <IntegrationsSection
    client:visible
    data={integrationsData}
    integrations={integrations}
    totalCount={allIntegrations.length}
    viewAllHref="/projects"
  />

  <TestimonialsSection client:visible data={testimonialsSectionData} testimonials={testimonials} />

  <InstitutionsSection
    client:visible
    badge={trustData.badge}
    title={trustData.sectionTitle}
    subtitle={trustData.subtitle}
    sponsors={sponsors}
  />

  <EnhancedCTA client:visible data={ctaData} />

  {/* Homepage footer section — snap target so users can reach the footer */}
  <section class="relative flex min-h-[60dvh] flex-col justify-center overflow-hidden snap-section">
    {/* Large ambient radial glow — much more visible */}
    <div
      class="absolute left-1/2 top-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.08] blur-3xl"
      style={{ background: 'radial-gradient(circle, var(--primary) 0%, transparent 60%)' }}
    />

    {/* Secondary smaller glow */}
    <div
      class="absolute right-1/4 top-1/3 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-[0.05] blur-3xl"
      style={{ background: 'radial-gradient(circle, var(--primary) 0%, transparent 70%)' }}
    />

    {/* Visible dot grid pattern */}
    <div
      class="absolute inset-0 -z-10 opacity-[0.03]"
      style={{
        backgroundImage: `radial-gradient(circle, rgba(255,255,255,0.5) 1px, transparent 1px)`,
        backgroundSize: '48px 48px',
      }}
    />

    {/* Giant watermark — positioned above footer content so it doesn't get cut */}
    <div class="pointer-events-none absolute top-0 left-0 right-0 h-[45%] flex items-end justify-center">
      <span class="select-none text-[16vw] font-black leading-none text-foreground/[0.01] tracking-tighter whitespace-nowrap translate-y-1/3">
        NukeHub
      </span>
    </div>

    <Footer />
  </section>
</BaseLayout>
