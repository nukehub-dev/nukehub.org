---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  description="NukeHub is a pioneering platform dedicated to the exploration and advancement of nuclear technology."
  keywords="nukehub, nuclear, technology, science, open source, innovation, collaboration, community, simulation, discussions"
  permalink="/"
>
  <main class="min-h-screen flex flex-col items-center justify-center px-4">
    <div class="text-center space-y-6">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-[var(--color-primary)]">
        NukeHub
      </h1>
      <p class="text-lg md:text-xl max-w-xl mx-auto text-[var(--color-text-muted)]">
        A pioneering platform dedicated to the exploration and advancement
        of nuclear technology.
      </p>
      <div class="pt-4 flex items-center justify-center gap-3">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-[var(--color-primary-100)] text-[var(--color-primary-700)]">
          Astro 5
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-[var(--color-primary-100)] text-[var(--color-primary-700)]">
          React 19
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-[var(--color-primary-100)] text-[var(--color-primary-700)]">
          Tailwind v4
        </span>
      </div>
      <p class="text-sm text-[var(--color-text-subtle)] pt-8">
        <a href="/sandbox" class="underline underline-offset-4 hover:text-[var(--color-primary)] transition-colors">
          View design token sandbox →
        </a>
      </p>
    </div>
  </main>
</BaseLayout>
