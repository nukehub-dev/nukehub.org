---
import BaseLayout from '@layouts/BaseLayout.astro';
import { AboutHero } from '@modules/about/components/AboutHero';
import { StoryTimeline } from '@modules/about/components/StoryTimeline';
import { MissionSection } from '@modules/about/components/MissionSection';
import { ValuesGrid } from '@modules/about/components/ValuesGrid';
import { SDGsSection } from '@modules/about/components/SDGsSection';
import { AboutCTA } from '@modules/about/components/AboutCTA';
import { AboutBackground } from '@modules/about/components/AboutBackground';
import { OrbitRings } from '@modules/about/components/decorations/OrbitRings';
import { FloatingParticles } from '@modules/about/components/decorations/FloatingParticles';
import { GradientOrbs } from '@modules/about/components/decorations/GradientOrbs';
import { ConnectingNodes } from '@modules/about/components/decorations/ConnectingNodes';
import { StarBurst } from '@modules/about/components/decorations/StarBurst';
import { loadYaml } from '@lib/loadYaml';
import type { AboutData } from '@modules/about/types';

const data = loadYaml<AboutData>('about/data/page.yml');
---

<BaseLayout
  title="About"
  description={data.hero.description}
  permalink="/about"
>
  <AboutBackground />

  <div class="relative z-10">
    {/* ===== HERO ===== */}
    <div class="relative">
      <OrbitRings client:load />
      <AboutHero
        client:load
        title={data.hero.title}
        description={data.hero.description}
        stats={data.hero.stats}
      />
    </div>

    {/* ===== STORY / TIMELINE ===== */}
    <div class="relative">
      <StoryTimeline
        client:visible
        title={data.story.title}
        subtitle={data.story.subtitle}
        milestones={data.story.milestones}
      />
    </div>

    {/* ===== MISSION ===== */}
    <div class="relative">
      <FloatingParticles client:visible count={24} />
      <MissionSection
        client:visible
        title={data.mission.title}
        subtitle={data.mission.subtitle}
        description={data.mission.description}
        points={data.mission.points}
      />
    </div>

    {/* ===== VALUES ===== */}
    <div class="relative">
      <GradientOrbs client:visible />
      <ValuesGrid
        client:visible
        title={data.values.title}
        subtitle={data.values.subtitle}
        items={data.values.items}
      />
    </div>

    {/* ===== SDGs ===== */}
    <div class="relative">
      <ConnectingNodes client:visible />
      <SDGsSection
        client:visible
        title={data.sdgs.title}
        subtitle={data.sdgs.subtitle}
        description={data.sdgs.description}
        goals={data.sdgs.goals}
        closingText={data.closing.text}
      />
    </div>

    {/* ===== CTA ===== */}
    <div class="relative">
      <AboutCTA
        client:visible
        title={data.community.title}
        description={data.community.description}
        primaryCta={data.community.primaryCta}
        secondaryCta={data.community.secondaryCta}
      />
    </div>
  </div>
</BaseLayout>
