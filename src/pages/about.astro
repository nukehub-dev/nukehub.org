---
import ManualPage from '@components/manual/ManualPage.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('manual', 'about');
if (!entry) {
  throw new Error('Manual entry "about" not found');
}
const { Content, headings } = await render(entry);
---

<ManualPage entry={entry} headings={headings}>
  <Content />
</ManualPage>
