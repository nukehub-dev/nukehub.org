---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  ClipboardList,
  Clock,
  ArrowRight,
  FileQuestion,
  Layers,
  ShieldCheck,
} from "lucide-react";
import { SurveyAuroraBackground } from "@modules/survey/components/decorations/SurveyAuroraBackground";
import { SurveyFloatingDots } from "@modules/survey/components/decorations/SurveyFloatingDots";
import type { Survey } from "@modules/survey/types";

const entries = await getCollection("surveys");

const surveys = entries.map((entry) => {
  const data = entry.data as Survey;
  const slug = data.slug || entry.id;
  const questionCount = data.pages
    ? data.pages.reduce((sum, page) => sum + page.questions.length, 0)
    : (data.questions ?? []).length;
  const pageCount = data.pages?.length ?? 1;
  const estimatedMinutes = Math.max(1, Math.round(questionCount * 0.6));
  return {
    ...data,
    slug,
    questionCount,
    pageCount,
    estimatedMinutes,
  };
});

const totalSurveys = surveys.length;
const totalQuestions = surveys.reduce(
  (sum, survey) => sum + survey.questionCount,
  0,
);
const averageMinutes =
  totalSurveys > 0
    ? Math.round(
        surveys.reduce((sum, s) => sum + s.estimatedMinutes, 0) / totalSurveys,
      )
    : 0;

const title = "Surveys";
const description = "Share your feedback and help shape the future of NukeHub.";
const keywords = "nukehub, surveys, feedback, community, nuclear";
const permalink = "/survey";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  permalink={permalink}
>
  <section class="relative overflow-hidden px-4 pt-28 pb-16 text-center">
    <SurveyAuroraBackground client:visible />
    <SurveyFloatingDots client:visible />
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-b from-primary/[0.03] via-transparent to-transparent"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary"
        >
          <ClipboardList size={16} />
          Surveys
        </div>
        <h1
          class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
        >
          Your <span
            class="inline-block bg-gradient-to-r from-primary to-[color-mix(in_oklch,var(--primary)_60%,var(--foreground))] bg-clip-text text-transparent"
            >feedback matters</span
          >
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground">
          Help us prioritize features, understand the community, and build
          better open-source tools for nuclear technology.
        </p>
      </div>
    </div>
  </section>

  <section class="relative z-10 mx-auto max-w-5xl px-4 pb-24 sm:px-6 lg:px-8">
    {
      surveys.length === 0 ? (
        <div class="bubble flex flex-col items-center justify-center p-10 text-center">
          <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary">
            <ClipboardList size={28} />
          </div>
          <h2 class="mt-4 text-xl font-semibold text-foreground">
            No surveys open right now
          </h2>
          <p class="mt-2 max-w-md text-muted-foreground">
            Check back soon — we run community surveys regularly to shape the
            future of NukeHub.
          </p>
        </div>
      ) : (
        <>
          <div class="mb-8 grid gap-4 sm:grid-cols-3">
            <div class="bubble flex items-center gap-4 p-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <ClipboardList size={20} />
              </div>
              <div class="text-left">
                <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                  Active surveys
                </p>
                <p class="text-lg font-semibold text-foreground">
                  {totalSurveys}
                </p>
              </div>
            </div>
            <div class="bubble flex items-center gap-4 p-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <FileQuestion size={20} />
              </div>
              <div class="text-left">
                <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                  Total questions
                </p>
                <p class="text-lg font-semibold text-foreground">
                  {totalQuestions}
                </p>
              </div>
            </div>
            <div class="bubble flex items-center gap-4 p-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                <Clock size={20} />
              </div>
              <div class="text-left">
                <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                  Avg. time
                </p>
                <p class="text-lg font-semibold text-foreground">
                  {averageMinutes} min
                </p>
              </div>
            </div>
          </div>

          <div class="grid gap-6 sm:grid-cols-2">
            {surveys.map((survey) => (
              <a
                href={`/survey/${survey.slug}`}
                class="group flex flex-col transition-all duration-200 hover:-translate-y-1"
              >
                <div class="bubble flex flex-1 flex-col p-6 transition-all hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10">
                  <div class="mb-4 flex items-center justify-between">
                    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform group-hover:scale-110">
                      <ClipboardList size={20} />
                    </div>
                    <div class="flex items-center gap-2 text-xs text-muted-foreground">
                      <span class="inline-flex items-center gap-1">
                        <Layers size={12} />
                        {survey.pageCount} page
                        {survey.pageCount === 1 ? "" : "s"}
                      </span>
                      <span>•</span>
                      <span class="inline-flex items-center gap-1">
                        <Clock size={12} />
                        {survey.estimatedMinutes} min
                      </span>
                    </div>
                  </div>

                  <h2 class="text-xl font-semibold text-foreground transition-colors group-hover:text-primary">
                    {survey.title}
                  </h2>

                  {survey.description && (
                    <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">
                      {survey.description}
                    </p>
                  )}

                  <div class="mt-5 flex items-center justify-between">
                    <span class="inline-flex items-center gap-1 text-xs text-muted-foreground">
                      <FileQuestion size={12} />
                      {survey.questionCount} question
                      {survey.questionCount === 1 ? "" : "s"}
                    </span>
                    <span class="inline-flex items-center gap-1 text-sm font-medium text-primary">
                      Take survey
                      <ArrowRight
                        size={16}
                        className="transition-transform group-hover:translate-x-1"
                      />
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <div class="mt-10 flex items-center justify-center gap-2 text-center text-xs text-muted-foreground">
            <ShieldCheck size={14} />
            Your responses are anonymous and used only to improve NukeHub.
          </div>
        </>
      )
    }
  </section>
</BaseLayout>
