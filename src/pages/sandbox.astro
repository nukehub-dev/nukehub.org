---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sandbox"
  description="Design token verification page"
  permalink="/sandbox"
>
  <main class="min-h-screen px-6 py-16 max-w-5xl mx-auto space-y-20">

    <!-- Typography -->
    <section class="space-y-6">
      <h2 class="text-sm font-mono uppercase tracking-widest opacity-60">Typography</h2>
      <div class="space-y-4">
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight">Display H1</h1>
        <h2 class="text-4xl md:text-5xl font-semibold tracking-tight">Heading H2</h2>
        <h3 class="text-2xl md:text-3xl font-semibold">Heading H3</h3>
        <p class="text-lg leading-relaxed max-w-2xl">
          Body text uses Geist at 16–18px with relaxed line-height for comfortable reading.
          The quick brown fox jumps over the lazy dog.
        </p>
        <p class="font-mono text-sm opacity-70">
          Mono text: const nucleus = {'{ protons: 92, neutrons: 146 }'};
        </p>
      </div>
    </section>

    <!-- Colors -->
    <section class="space-y-6">
      <h2 class="text-sm font-mono uppercase tracking-widest opacity-60">Primary Scale</h2>
      <div class="grid grid-cols-3 md:grid-cols-5 gap-3">
        {['50','100','200','300','400','500','600','700','800','900'].map((step) => {
          const isDark = parseInt(step) >= 500;
          const bg = 'var(--color-primary-' + step + ')';
          const fg = isDark ? 'white' : 'var(--color-text)';
          return (
            <div class="space-y-2">
              <div
                class="h-16 rounded-lg flex items-end p-2 text-xs font-mono"
                style={'background: ' + bg + '; color: ' + fg + ';'}
              >
                {step}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Surfaces -->
    <section class="space-y-6">
      <h2 class="text-sm font-mono uppercase tracking-widest opacity-60">Surfaces</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="h-24 rounded-xl border p-4 text-sm" style="background: var(--color-surface); border-color: var(--color-border);">
          surface
        </div>
        <div class="h-24 rounded-xl p-4 text-sm" style="background: var(--color-surface-muted);">
          surface-muted
        </div>
        <div class="h-24 rounded-xl shadow-lg p-4 text-sm" style="background: var(--color-surface-elevated);">
          surface-elevated
        </div>
        <div class="h-24 rounded-xl p-4 text-sm" style="background: var(--color-surface-inverse); color: var(--color-text-inverted);">
          surface-inverse
        </div>
      </div>
    </section>

    <!-- Text colors -->
    <section class="space-y-6">
      <h2 class="text-sm font-mono uppercase tracking-widest opacity-60">Text Colors</h2>
      <div class="space-y-3 text-lg">
        <p style="color: var(--color-text)">text — Primary body color</p>
        <p style="color: var(--color-text-muted)">text-muted — Secondary/muted text</p>
        <p style="color: var(--color-text-subtle)">text-subtle — Tertiary/caption text</p>
        <p class="inline-block px-3 py-1 rounded" style="background: var(--color-surface-inverse); color: var(--color-text-inverted)">
          text-inverted — On dark backgrounds
        </p>
      </div>
    </section>

    <!-- Theme Controls -->
    <section class="space-y-6">
      <h2 class="text-sm font-mono uppercase tracking-widest opacity-60">Theme Controls</h2>
      <div class="flex flex-wrap items-center gap-6">
        <button
          id="theme-toggle"
          class="px-4 py-2 rounded-lg border text-sm font-medium transition-colors cursor-pointer"
          style="border-color: var(--color-border); background: var(--color-surface-elevated);"
        >
          Toggle Dark Mode
        </button>

        <div class="flex items-center gap-3">
          <span class="text-sm opacity-70">Accent:</span>
          {[
            { name: 'red',    hsl: 'oklch(61% 0.209 27)' },
            { name: 'orange', hsl: 'oklch(70% 0.177 48)' },
            { name: 'green',  hsl: 'oklch(67% 0.162 144)' },
            { name: 'cyan',   hsl: 'oklch(73% 0.126 211)' },
            { name: 'purple', hsl: 'oklch(52% 0.215 321)' },
          ].map((color) => (
            <button
              data-accent={color.name}
              class="w-8 h-8 rounded-full border-2 cursor-pointer transition-transform hover:scale-110 accent-swatch"
              style={'background: ' + color.hsl + '; border-color: transparent;'}
              title={color.name}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Animation Demo -->
    <section class="space-y-6">
      <h2 class="text-sm font-mono uppercase tracking-widest opacity-60">Animation Presets</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 rounded-xl border text-center text-sm" style="border-color: var(--color-border)">
          <code class="font-mono text-xs opacity-70 block mb-2">fadeIn</code>
          <div class="h-8 rounded" style="background: var(--color-primary-200)" />
        </div>
        <div class="p-4 rounded-xl border text-center text-sm" style="border-color: var(--color-border)">
          <code class="font-mono text-xs opacity-70 block mb-2">fadeInUp</code>
          <div class="h-8 rounded" style="background: var(--color-primary-300)" />
        </div>
        <div class="p-4 rounded-xl border text-center text-sm" style="border-color: var(--color-border)">
          <code class="font-mono text-xs opacity-70 block mb-2">spring</code>
          <div class="h-8 rounded" style="background: var(--color-primary-400)" />
        </div>
        <div class="p-4 rounded-xl border text-center text-sm" style="border-color: var(--color-border)">
          <code class="font-mono text-xs opacity-70 block mb-2">stagger</code>
          <div class="h-8 rounded" style="background: var(--color-primary-500)" />
        </div>
      </div>
      <p class="text-sm opacity-60">
        Framer Motion variants are defined in <code class="font-mono">src/lib/animations.ts</code>.
        Import them and use with <code class="font-mono">motion.div</code> or <code class="font-mono">whileInView</code>.
      </p>
    </section>

  </main>

  <script is:inline>
    (function () {
      const html = document.documentElement;
      const toggle = document.getElementById('theme-toggle');
      const swatches = document.querySelectorAll('.accent-swatch');

      // Dark mode toggle
      toggle?.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      // Accent picker
      swatches.forEach((btn) => {
        btn.addEventListener('click', () => {
          const accent = btn.getAttribute('data-accent');
          html.setAttribute('data-accent', accent);
          localStorage.setItem('accent', accent);
          // Update active state
          swatches.forEach((s) => (s.style.borderColor = 'transparent'));
          btn.style.borderColor = 'var(--color-text)';
        });
      });

      // Restore preferences
      const savedTheme = localStorage.getItem('theme');
      const savedAccent = localStorage.getItem('accent') || 'orange';
      if (savedTheme) html.setAttribute('data-theme', savedTheme);
      if (savedAccent) {
        html.setAttribute('data-accent', savedAccent);
        const active = document.querySelector(`[data-accent="${savedAccent}"]`);
        if (active) active.style.borderColor = 'var(--color-text)';
      }
    })();
  </script>
</BaseLayout>
