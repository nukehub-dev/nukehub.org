---
import BaseLayout from "@layouts/BaseLayout.astro";
import { AdminLandingPage } from "@components/shared/AdminLanding";

const title = "Administration";
const description = "NukeHub administration: surveys and newsletter.";
const permalink = "/admin";
---

<BaseLayout title={title} description={description} permalink={permalink}>
  <section class="relative min-h-[calc(100vh-4rem)] px-4 py-16">
    <div class="relative z-10 mx-auto max-w-4xl">
      <div class="mb-8">
        <h1
          class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl"
        >
          Administration
        </h1>
        <p class="mt-2 text-muted-foreground">
          Survey and newsletter management for NukeHub staff.
        </p>
      </div>
      <AdminLandingPage
        url={import.meta.env.PUBLIC_AUTH_URL}
        realm={import.meta.env.PUBLIC_AUTH_REALM}
        clientId={import.meta.env.PUBLIC_AUTH_CLIENT_ID}
        client:only="react"
      />
    </div>
  </section>
</BaseLayout>
