---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  permalink?: string;
  image?: string;
}

const { title, description, keywords, permalink, image } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  permalink={permalink}
  image={image}
>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <slot />
  </div>
</BaseLayout>
