---
import "@styles/global.css";
import { AuthHeader } from "@components/layout/AuthHeader";
import { Footer } from "@components/layout/Footer";
import { ScrollProgress } from "@components/shared/ScrollProgress";
import { CustomCursor } from "@components/shared/CustomCursor";
import { GlobalContextMenu } from "@components/shared/GlobalContextMenu";
import { PerformanceMonitor } from "@components/shared/PerformanceMonitor";
import GrainOverlay from "@components/shared/GrainOverlay.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  permalink?: string;
  image?: string;
  bodyClass?: string;
  htmlClass?: string;
  showFooter?: boolean;
}

const {
  title,
  description = "NukeHub is a pioneering platform dedicated to the exploration and advancement of nuclear technology.",
  keywords = "nukehub, nuclear, technology, science, open source, innovation, collaboration, community, simulation",
  permalink = "/",
  image = "/assets/images/nukehub.png",
  bodyClass,
  htmlClass,
  showFooter = true,
} = Astro.props;

const siteUrl = "https://nukehub.org";
const pageTitle = title ? `${title} | NukeHub` : "NukeHub";
const canonicalUrl = `${siteUrl}${permalink}`;
---

<!doctype html>
<html lang="en" class={htmlClass || ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="NukeHub RSS Feed"
      href={`${siteUrl}/rss.xml`}
    />
    <link rel="icon" type="image/svg+xml" href="/assets/images/nukehub.svg" />

    <!-- Preload Geist fonts for faster first paint -->
    <link
      rel="preload"
      href="/fonts/Geist-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="NukeHub" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- Schema.org -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "NukeHub",
        image: `${siteUrl}/assets/images/nukehub.png`,
        url: siteUrl,
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "NukeHub",
        description,
        url: siteUrl,
        logo: `${siteUrl}/assets/images/nukehub.svg`,
        foundingDate: "2023",
        founders: [{ "@type": "Person", name: "Ahnaf Tahmid Chowdhury" }],
        email: "tahmid@nukehub.org",
        sameAs: [
          "https://github.com/nukehub-dev",
          "https://linkedin.com/company/nukehub/",
        ],
      })}
    />

    <!--
      ============================================================
      Theme init script — MUST be inline and blocking to prevent
      flash of unstyled content (FOUC).
      ============================================================
    -->
    <script is:inline>
      (function () {
        var html = document.documentElement;
        var storedTheme = localStorage.getItem("theme");
        var storedAccent = localStorage.getItem("accent") || "orange";
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        // Resolve 'system' to an actual light/dark value immediately
        var resolvedTheme;
        if (storedTheme === "light" || storedTheme === "dark") {
          resolvedTheme = storedTheme;
        } else if (storedTheme === "system" || !storedTheme) {
          resolvedTheme = prefersDark ? "dark" : "light";
        } else {
          resolvedTheme = "light";
        }

        html.setAttribute("data-theme", resolvedTheme);
        html.setAttribute("data-accent", storedAccent);

        // Update theme-color meta for mobile browsers
        var metaThemeColor = document.querySelector('meta[name="theme-color"]');
        if (metaThemeColor) {
          var accentMap = {
            red: { light: "#e03131", dark: "#c92a2a" },
            orange: { light: "#f37524", dark: "#d65a0f" },
            green: { light: "#40c057", dark: "#2f9e44" },
            cyan: { light: "#15aabf", dark: "#1098ad" },
            purple: { light: "#be4bdb", dark: "#9c36b5" },
          };
          var color = (accentMap[storedAccent] || accentMap.orange)[
            resolvedTheme
          ];
          metaThemeColor.setAttribute("content", color);
        }
      })();
    </script>
  </head>

  <body class={`min-h-screen flex flex-col ${bodyClass || ""}`}>
    <ScrollProgress client:idle />
    <CustomCursor client:idle />
    <GlobalContextMenu client:idle />
    <PerformanceMonitor client:idle />
    <GrainOverlay />

    <AuthHeader
      client:only="react"
      url={import.meta.env.PUBLIC_KEYCLOAK_URL}
      realm={import.meta.env.PUBLIC_KEYCLOAK_REALM}
      clientId={import.meta.env.PUBLIC_KEYCLOAK_CLIENT_ID}
    />

    <main class="flex-1" role="main">
      <slot />
    </main>

    {showFooter && <Footer />}

    <!-- Scroll to top -->
    <button
      id="scroll-top"
      class="fixed bottom-6 right-6 z-40 inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:brightness-110"
      aria-label="Scroll to top"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg
      >
    </button>

    <script is:inline>
      (function () {
        var btn = document.getElementById("scroll-top");
        if (!btn) return;
        window.addEventListener("scroll", function () {
          if (window.scrollY > 300) {
            btn.classList.remove("opacity-0", "pointer-events-none");
            btn.classList.add("opacity-100", "pointer-events-auto");
          } else {
            btn.classList.remove("opacity-100", "pointer-events-auto");
            btn.classList.add("opacity-0", "pointer-events-none");
          }
        });
        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      })();
    </script>
  </body>
</html>
