---
import "@styles/global.css";
import { AuthHeader } from "@components/layout/AuthHeader";
import { Footer } from "@components/layout/Footer";
import { ScrollProgress } from "@components/shared/ScrollProgress";
import { CustomCursor } from "@components/shared/CustomCursor";
import { GlobalContextMenu } from "@components/shared/GlobalContextMenu";
import { PerformanceMonitor } from "@components/shared/PerformanceMonitor";
import GrainOverlay from "@components/shared/GrainOverlay.astro";
import { CookieConsent } from "@components/shared/CookieConsent";
import Analytics from "@components/shared/Analytics.astro";
import { PageLoader } from "@components/shared/PageLoader";
import { ErrorBoundary } from "@components/shared/ErrorBoundary";
import { getCollection } from "astro:content";
import { resolveProjectUrl } from "@lib/projects";
import { CommandPaletteManager } from "@components/shared/CommandPaletteManager";
import type {
  CommandPaletteProject,
  CommandPalettePerson,
  CommandPaletteEvent,
  CommandPaletteIntegration,
  CommandPalettePage,
} from "@components/shared/CommandPalette";
import type { Survey } from "@modules/survey/types";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  permalink?: string;
  image?: string;
  ogImage?: string;
  bodyClass?: string;
  htmlClass?: string;
  showFooter?: boolean;
}

const {
  title,
  description = "NukeHub is a pioneering platform dedicated to the exploration and advancement of nuclear technology.",
  keywords = "nukehub, nuclear, technology, science, open source, innovation, collaboration, community, simulation",
  permalink = "/",
  image = "/assets/images/nukehub.png",
  ogImage,
  bodyClass,
  htmlClass,
  showFooter = true,
} = Astro.props;

const siteUrl = "https://nukehub.org";
const pageTitle = title ? `${title} | NukeHub` : "NukeHub";
const canonicalUrl = `${siteUrl}${permalink}`;

function resolveOgImage(
  permalink: string,
  fallback: string,
  explicit?: string,
): string {
  if (explicit) return explicit;
  if (permalink === "/" || permalink === "") return "/og/home.png";
  if (permalink === "/roadmap") return "/og/roadmap.png";
  const projectSlugs = [
    "nuke-lab",
    "nuke-ide",
    "nrms",
    "nuke-analytics",
    "nukebox",
  ];
  const slug = permalink.replace(/^\//, "");
  if (projectSlugs.includes(slug)) {
    return `/og/projects/${slug}.png`;
  }
  return fallback;
}

const resolvedOgImage = `${siteUrl}${resolveOgImage(permalink, image, ogImage)}`;

// Load projects from content collection for dynamic nav/footer
const projectEntries = await getCollection("projects");
const sortedEntries = projectEntries.sort(
  (a, b) => (a.data.order ?? Infinity) - (b.data.order ?? Infinity),
);

// Pass simple JSON-serializable project entries to client components
// (React components can't be serialized across server/client boundary)
const projectNavEntries = sortedEntries.map((entry) => {
  const url = resolveProjectUrl(entry);
  return {
    title: entry.data.title,
    url,
    newpage: url.startsWith("http"),
    iconName: entry.data.icon || "Factory",
  };
});

const projectFooterEntries = sortedEntries.map((entry) => {
  const url = resolveProjectUrl(entry);
  return {
    title: entry.data.title,
    url,
    newpage: url.startsWith("http"),
    iconName: entry.data.icon || "Factory",
  };
});

// Build command palette index from content collections
const commandPaletteProjects: CommandPaletteProject[] = sortedEntries.map(
  (entry) => ({
    id: entry.id,
    title: entry.data.title,
    description: entry.data.description || "",
    url: resolveProjectUrl(entry),
    iconName: entry.data.icon || "Factory",
    tags: entry.data.tags,
    category: "Projects",
  }),
);

const [peopleEntries, eventEntries, integrationEntries, surveyEntries] =
  await Promise.all([
    getCollection("people"),
    getCollection("events"),
    getCollection("integrations"),
    getCollection("surveys"),
  ]);

const commandPalettePeople: CommandPalettePerson[] = peopleEntries.map(
  (entry) => ({
    id: entry.id,
    name: entry.data.name,
    role: entry.data.role,
    organization: entry.data.organization,
    url: entry.data.url,
    category: "People",
  }),
);

const commandPaletteEvents: CommandPaletteEvent[] = eventEntries.map(
  (entry) => ({
    id: entry.id,
    title: entry.data.title,
    description: entry.data.description,
    url: entry.data.url,
    category: "Events",
  }),
);

const commandPaletteIntegrations: CommandPaletteIntegration[] =
  integrationEntries.map((entry) => ({
    id: entry.id,
    name: entry.data.name,
    description: entry.data.description,
    url: entry.data.url,
    categoryName: entry.data.category,
    category: "Integrations",
  }));

const surveyPages: CommandPalettePage[] = surveyEntries.map((entry) => {
  const survey = entry.data as Survey;
  const slug = survey.slug || entry.id;
  return {
    id: `survey-${slug}`,
    title: survey.title,
    url: `/surveys/${slug}`,
    category: "Pages",
  };
});

const commandPalettePages: CommandPalettePage[] = [
  { id: "home", title: "Home", url: "/", category: "Pages" },
  { id: "about", title: "About", url: "/about", category: "Pages" },
  { id: "projects", title: "Projects", url: "/projects", category: "Pages" },
  { id: "people", title: "People", url: "/people", category: "Pages" },
  { id: "events", title: "Events", url: "/events", category: "Pages" },
  { id: "surveys", title: "Surveys", url: "/surveys", category: "Pages" },
  { id: "contact", title: "Contact", url: "/contact", category: "Pages" },
  { id: "support", title: "Support Us", url: "/support", category: "Pages" },
  {
    id: "acknowledgment",
    title: "Acknowledgment",
    url: "/acknowledgment",
    category: "Pages",
  },
  { id: "roadmap", title: "Roadmap", url: "/roadmap", category: "Pages" },
  {
    id: "changelog",
    title: "Changelog",
    url: "/changelog",
    category: "Pages",
  },
  ...surveyPages,
];
---

<!doctype html>
<html lang="en" class={htmlClass || ""}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="text/markdown"
      title={title || "NukeHub page — Markdown"}
      href={canonicalUrl}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="NukeHub RSS Feed"
      href={`${siteUrl}/rss.xml`}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />

    <!--
      Dynamic favicon: swaps the tab icon to the current theme accent and
      background once CSS variables are available. Falls back to /favicon.svg
      when JS is disabled.
    -->
    <script>
      import { updateFavicon, updateThemeColor } from "@lib/favicon";
      updateFavicon();
      updateThemeColor();
    </script>

    <!-- Preload Geist fonts for faster first paint -->
    <link
      rel="preload"
      href="/fonts/Geist-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <title>{pageTitle}</title>
    <meta name="title" content={pageTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="NukeHub" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Schema.org -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "NukeHub",
        image: `${siteUrl}/assets/images/nukehub.png`,
        url: siteUrl,
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "NukeHub",
        description,
        url: siteUrl,
        logo: `${siteUrl}/assets/images/nukehub.svg`,
        foundingDate: "2023",
        founders: [{ "@type": "Person", name: "Ahnaf Tahmid Chowdhury" }],
        email: "tahmid@nukehub.org",
        sameAs: [
          "https://github.com/nukehub-dev",
          "https://linkedin.com/company/nukehub/",
        ],
      })}
    />

    <!--
      ============================================================
      Theme init script — MUST be inline and blocking to prevent
      flash of unstyled content (FOUC).
      ============================================================
    -->
    <script is:inline>
      (function () {
        var html = document.documentElement;
        var storedTheme = localStorage.getItem("theme");
        var storedAccent = localStorage.getItem("accent") || "orange";
        var prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;

        // Resolve 'system' to an actual light/dark value immediately
        var resolvedTheme;
        if (storedTheme === "light" || storedTheme === "dark") {
          resolvedTheme = storedTheme;
        } else if (storedTheme === "system" || !storedTheme) {
          resolvedTheme = prefersDark ? "dark" : "light";
        } else {
          resolvedTheme = "light";
        }

        html.setAttribute("data-theme", resolvedTheme);
        html.setAttribute("data-accent", storedAccent);

        // Update theme-color meta for mobile browsers
        var metaThemeColor = document.querySelector('meta[name="theme-color"]');
        if (metaThemeColor) {
          var accentMap = {
            red: { light: "#e03131", dark: "#c92a2a" },
            orange: { light: "#f37524", dark: "#d65a0f" },
            green: { light: "#40c057", dark: "#2f9e44" },
            cyan: { light: "#15aabf", dark: "#1098ad" },
            purple: { light: "#be4bdb", dark: "#9c36b5" },
          };
          var color = (accentMap[storedAccent] || accentMap.orange)[
            resolvedTheme
          ];
          metaThemeColor.setAttribute("content", color);
        }
      })();
    </script>
  </head>

  <body class={`min-h-screen flex flex-col ${bodyClass || ""}`}>
    <a
      href="#main-content"
      class="fixed left-4 top-4 z-[9999] -translate-y-[150%] rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-lg transition-transform focus-visible:translate-y-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40"
    >
      Skip to content
    </a>

    <PageLoader client:load />

    <ScrollProgress client:idle />
    <CustomCursor client:idle />
    <GlobalContextMenu client:idle />
    <PerformanceMonitor client:idle />
    <GrainOverlay />
    <Analytics />
    <CookieConsent client:load />

    <CommandPaletteManager
      client:load
      projects={commandPaletteProjects}
      people={commandPalettePeople}
      events={commandPaletteEvents}
      integrations={commandPaletteIntegrations}
      pages={commandPalettePages}
    />

    <ErrorBoundary client:load>
      <AuthHeader
        client:only="react"
        url={import.meta.env.PUBLIC_AUTH_URL}
        realm={import.meta.env.PUBLIC_AUTH_REALM}
        clientId={import.meta.env.PUBLIC_AUTH_CLIENT_ID}
        projectEntries={projectNavEntries}
      />
    </ErrorBoundary>

    <main id="main-content" class="flex-1" role="main" tabindex="-1">
      <slot />
    </main>

    {showFooter && <Footer projectEntries={projectFooterEntries} client:load />}

    <!-- Scroll to top -->
    <button
      id="scroll-top"
      class="fixed bottom-6 right-6 z-40 inline-flex h-10 w-10 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-lg opacity-0 pointer-events-none transition-all duration-300 hover:brightness-110"
      aria-label="Scroll to top"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="m18 15-6-6-6 6"></path></svg
      >
    </button>

    <script is:inline>
      (function () {
        var btn = document.getElementById("scroll-top");
        if (!btn) return;
        window.addEventListener("scroll", function () {
          if (window.scrollY > 300) {
            btn.classList.remove("opacity-0", "pointer-events-none");
            btn.classList.add("opacity-100", "pointer-events-auto");
          } else {
            btn.classList.remove("opacity-100", "pointer-events-auto");
            btn.classList.add("opacity-0", "pointer-events-none");
          }
        });
        btn.addEventListener("click", function () {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      })();
    </script>
    <script is:inline>
      (function () {
        function showCookieBanner() {
          var banner = document.querySelector("[data-cookie-banner]");
          if (!banner) return;
          banner.classList.remove(
            "translate-y-6",
            "opacity-0",
            "pointer-events-none",
          );
          banner.classList.add(
            "translate-y-0",
            "opacity-100",
            "pointer-events-auto",
          );
        }

        document.addEventListener("click", function (e) {
          var target = e.target.closest("[data-cookie-settings]");
          if (!target) return;
          e.preventDefault();
          try {
            localStorage.removeItem("cookie-consent");
            showCookieBanner();
            window.dispatchEvent(
              new CustomEvent("cookie-consent-change", {
                detail: { consent: null },
              }),
            );
          } catch (err) {
            console.error("Failed to reset cookie consent:", err);
          }
        });
      })();
    </script>
    <script>
      if (!import.meta.env.DEV && "serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js", { scope: "/" })
            .catch((err) => {
              console.error("Service worker registration failed:", err);
            });
        });
      }
    </script>
  </body>
</html>
